# MCP client token whitelist (comma/newline separated) — REQUIRED, no default.
# Any token in this list authenticates an MCP client with full, equal access.
# Generate high-entropy values, e.g. `openssl rand -hex 32`.
DELAMAIN_AUTH_TOKENS=

# Internal gateway<->Java backend token (optional). If unset, the container
# entrypoint generates a random one and shares it between the two in-container
# processes; it is never exposed to MCP clients. Set only if you need a fixed,
# known internal token.
JADX_INTERNAL_TOKEN=

# Host directory containing APK/JAR/AAR/DEX files. It is mounted read-only at /apks.
JADX_APK_DIR=/data/apks

# Host directory containing Gateway config.toml. It is mounted read-only at /data/config.
JADX_CONFIG_DIR=/data/config

# Public Gateway port (optional). The Java service is internal-only.
JADX_GATEWAY_PORT=8651

# JVM options for the Java backend (optional). Memory scales with the class tree:
# a very large (~238K-class) APK holds a ~3.6 GB loaded floor plus indices.
# Default empty = the heap ceiling is DERIVED FROM THE CONTAINER at startup
# (cgroup limit x DELAMAIN_HEAP_PERCENT, minus DELAMAIN_HEAP_RESERVE_MB for the
# gateway/OS/mmap index, capped at DELAMAIN_HEAP_MAX_MB) -- see
# gateway/src/heap_config.py. Set this only to override that:
#   JAVA_OPTS=-XX:MaxRAMPercentage=75   (dedicated container; NOTE: without
#                                        `docker run -m` the JVM computes this
#                                        against the HOST's RAM, not the container)
#   JAVA_OPTS=-Xmx8g                    (explicit ceiling)
# An -Xmx / -XX:MaxRAMPercentage here disables the derived value entirely.
JAVA_OPTS=

# Heap-derivation knobs (optional; defaults shown). Only the cap usually needs
# touching -- raise it for a very large APK on a big dedicated container.
#   DELAMAIN_HEAP_PERCENT=60
#   DELAMAIN_HEAP_RESERVE_MB=1024
#   DELAMAIN_HEAP_MAX_MB=10240
